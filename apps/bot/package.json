{
  "name": "@oracle/bot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@oracle/engine": "workspace:*",
    "@oracle/storage": "workspace:*",
    "@oracle/runtime": "workspace:*",
    "@oracle/notify": "workspace:*",
    "@oracle/booking": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
