{
  "name": "@oracle/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check .",
    "test": "vitest run --passWithNoTests",
    "smoke": "node --experimental-vm-modules dist/smoke.js",
    "start": "node --max-old-space-size=512 dist/index.js",
    "start:now": "node --max-old-space-size=512 dist/index.js --run-now",
    "refresh-kaggle": "node dist/index.js --refresh-kaggle",
    "export-store": "node dist/export-store.js",
    "import-backfill": "node dist/import-backfill.js"
  },
  "dependencies": {
    "@oracle/engine": "workspace:*",
    "@oracle/storage": "workspace:*",
    "@oracle/llm": "workspace:*",
    "@oracle/runtime": "workspace:*",
    "@oracle/notify": "workspace:*",
    "@oracle/booking": "workspace:*",
    "@oracle/bot": "workspace:*",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
