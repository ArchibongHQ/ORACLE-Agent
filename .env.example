# ORACLE Agent — environment template
# Copy to .env and fill in. Missing optional keys = that feature is silently skipped.
# NEVER commit .env (it is gitignored).

# ── LLM providers ─────────────────────────────────────────────────────────────
CLAUDE_API_KEY=            # required — Claude Opus decision tier
GEMINI_API_KEY=            # required — Gemini fallback + odds/data acquisition
OPENROUTER_API_KEY=        # optional — Tier 2/3 fallback cascade (GLM/GPT-oss/DeepSeek)
KIMI_API_KEY=              # optional — Kimi K2.6 swarm workers (platform.moonshot.ai)
PERPLEXITY_API_KEY=        # optional — T0 news/team intelligence (with ENABLE_NEWS_INTEL)

# ── Data sources ──────────────────────────────────────────────────────────────
ODDS_API_KEY=              # required — the-odds-api.com live odds + CLV (free tier: 500 credits/mo)
FOOTBALL_DATA_API_KEY=     # required for resolve — football-data.org post-match results
API_FOOTBALL_KEY=          # optional — API-Football fixtures/lineups fallback
ODDSPAPI_KEY=              # optional — OddsPapi fallback odds provider
OPENWEATHER_API_KEY=       # optional — match-day weather GBM feature
KAGGLE_USERNAME=           # optional — weekly Kaggle dataset refresh (or ~/.kaggle/kaggle.json)
KAGGLE_KEY=                # optional — pairs with KAGGLE_USERNAME

# ── Feature flags ─────────────────────────────────────────────────────────────
ENABLE_NEWS_INTEL=false           # true + PERPLEXITY_API_KEY → T0 news intel
ENABLE_SWARM=false                # true + KIMI/OPENROUTER key → swarm voting
ENABLE_SPORTYBET_BOOKING=false    # true → worker books an anonymous accumulator
ENABLE_WEB_SEARCH_FALLBACK=true   # web-search odds consensus when Odds API fails
ORACLE_AUTORESEARCH_ENABLED=false # autonomous SkillOpt loop (also needs GPU/VPS)

# ── Tuning ────────────────────────────────────────────────────────────────────
BANKROLL=1000
BATCH_CONCURRENCY=8
WEB_ODDS_MIN_CONSENSUS=3
WEB_ODDS_VARIANCE_THRESHOLD=0.025
PORT=8787                  # web UI port (binds 127.0.0.1)

# ── Push notifications (@oracle/notify — all optional) ───────────────────────
TELEGRAM_BOT_TOKEN=        # with TELEGRAM_CHAT_ID → Telegram push + punt bot
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=
MAIL_API_KEY=              # Resend-style HTTP mail API
MAIL_FROM=
MAIL_TO=
# MAIL_ENDPOINT=https://api.resend.com/emails
OPENCLAW_GATEWAY_URL=      # e.g. http://127.0.0.1:18789
OPENCLAW_TOKEN=
# OPENCLAW_AGENT_ID=main
