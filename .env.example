# ORACLE Agent — environment template
# Copy to .env and fill in. Missing optional keys = that feature is silently skipped.
# NEVER commit .env (it is gitignored).

# ── LLM providers ─────────────────────────────────────────────────────────────
CLAUDE_API_KEY=            # required — Claude Opus decision tier
GEMINI_API_KEY=            # required — Gemini fallback + odds/data acquisition
OPENROUTER_API_KEY=        # optional — Tier 2/3 fallback cascade (DeepSeek/GLM/GPT-oss)
KIMI_API_KEY=              # optional — Kimi K2.6 swarm workers (platform.moonshot.ai)
PERPLEXITY_API_KEY=        # optional — T0 news/team intelligence (with ENABLE_NEWS_INTEL)

# ── Data sources ──────────────────────────────────────────────────────────────
ODDS_API_KEY=              # required — the-odds-api.com live odds + CLV (free tier: 500 credits/mo)
FOOTBALL_DATA_API_KEY=     # required for resolve — football-data.org post-match results
API_FOOTBALL_KEY=          # optional — API-Football fixtures/lineups fallback
SHARPAPI_IO_KEY=           # optional — SharpAPI.io sharp odds fallback (sharpapi.io — NOT sharpapi.com)
ODDS_API_IO_KEY=           # optional — Odds-API.io fallback odds (free: 100 req/hr, odds-api.io)
SPORTS_GAMEODDS_KEY=       # optional — SportsGameOdds fallback odds (free: 1,000 objects/mo)
OPENWEATHER_API_KEY=       # optional — match-day weather GBM feature
KAGGLE_USERNAME=           # optional — weekly Kaggle dataset refresh (or ~/.kaggle/kaggle.json)
KAGGLE_KEY=                # optional — pairs with KAGGLE_USERNAME

# ── Feature flags ─────────────────────────────────────────────────────────────
ENABLE_NEWS_INTEL=false           # true → T0 news intel. Wave-4: runs keyless (Google-AI-Mode + local
                                  # Claude reshape) when no PERPLEXITY/GEMINI key — a missing key is
                                  # never a blocker. A provider key only upgrades quality, not gating.
ORACLE_CLOUD_NEWS_SYNC=false      # merge cloud-routine news/xG from the git `data` branch after daily
                                  # enrichment (see workflows/cloud_news_intel.md)
ENABLE_SWARM=false                # true + KIMI/OPENROUTER key → swarm voting
ENABLE_SPORTYBET_BOOKING=false    # true → worker books an anonymous accumulator
ENABLE_WEB_SEARCH_FALLBACK=true   # web-search odds consensus when Odds API fails
ORACLE_AUTORESEARCH_ENABLED=false # autonomous SkillOpt loop (also needs GPU/VPS)
ORACLE_FETCH_LIVE_XG=on           # on → the standalone off-peak worker cron (02:00 WAT, decoupled from
                                  # 09:30 acquisition — PR-7) runs FotMob live-xG (1000+ comps) + rebuilds
                                  # the rolling xG prior, filling obscure-league gaps. Headless, own
                                  # off-peak slot — no longer stacks with the 09:30 swarm (was the BSOD
                                  # risk this defaulted OFF for); set off to disable entirely.
ORACLE_FETCH_XG_FALLBACK=on       # (PR-19) on → after the FotMob+rebuild pass above, run the Google-AI-Mode
                                  # xG fallback (fetch_xg_fallback.py) over whatever teams are STILL missing
                                  # xG — same 02:00 WAT window, never inline in 09:30. Lowest-confidence tier
                                  # (LLM prose extraction); off = byte-identical to pre-PR-19 behavior.
ORACLE_XG_FALLBACK_MAX_TEAMS=25   # (PR-19) cap on residual teams sent to the AI-Mode fallback per run —
                                  # each is a real Playwright page load.
ORACLE_FETCH_SQUAD_AVAILABILITY=off # (PR-25) DEFAULT OFF, and correctly so — the Saturday Kaggle
                                  # refresh (apps/worker/src/dailyAcquisition.ts's runWeeklyKaggleRefresh)
                                  # now derives match-day squad availability_idx UNCONDITIONALLY, every
                                  # week, regardless of this flag — that's what actually fixed the
                                  # previously-stale availability_features.csv (feeds the Wave-2
                                  # availability→lambda multipliers). This flag only gates a SEPARATE,
                                  # redundant re-derivation inside the DAILY 09:30 acquisition
                                  # (tools/acquire_daily.py's _maybe_fetch_squad_availability) against
                                  # the same Kaggle snapshot the Saturday job already refreshed — since
                                  # that snapshot only changes weekly, running this daily just recomputes
                                  # a byte-identical CSV until the next Saturday. Leave off; on wastes a
                                  # ~5min subprocess in the daily run for no new data.
ORACLE_FETCH_WEATHER=off          # (PR-25) DEFAULT OFF — NOT a cheap toggle. on → scrape_fixtures.py
                                  # fetches Open-Meteo forecast weather per fixture, which activates
                                  # @oracle/engine's applyEnvironmentalPenalties — an already-live,
                                  # UNCONDITIONAL lambda adjustment (wind >18.5mph / rain >5mm dampen
                                  # both teams' goal expectancy) that has been fully dormant since
                                  # port from the original monolith, simply for lack of data. Flip on
                                  # only as a deliberate, informed decision — see tools/scrape_fixtures.py's
                                  # _load_weather_table comment for the full explanation.
# Final-arbiter decision tier (local Claude Code CLI, packages/llm/src/callClaudeCode.ts).
# Applies globally — every fixture in every analysis pipeline (worker daily batch,
# /punt, CLI fixture) routes through packages/engine/src/decision/index.ts's decide(),
# which is the single call site this gates. When true, Claude reviews the upstream
# cascade's draft pick against stats/news-intel/rationale/engine-math and ratifies,
# overrides (only with a market from the eligible list), or flags grade="MISSING_DATA"
# when the evidence is too thin to decide. Requires the `claude` CLI on PATH (or
# CLAUDE_BIN set to its path) — falls back to the draft pick with
# decision.arbiterStatus="unverified" on any failure (binary missing, 45s timeout,
# unparseable response). Never blocks the pipeline either way.
ORACLE_LOCAL_DECISION=true

# Hard-pin the local Claude Code transport so a worker run as a background/Windows
# Service (which lacks the interactive user's PATH) can still spawn the CLI:
#  - ORACLE_RUNTIME=local forces isLocalRuntime()=true regardless of PATH probe
#    (leave blank to auto-detect: claude-on-PATH > win32 tiebreaker)
#  - CLAUDE_BIN = absolute path to the claude binary, e.g.
#    CLAUDE_BIN=C:\Users\<you>\.local\bin\claude.exe — overrides PATH resolution
# Without these the decision cascade silently degrades to free OpenRouter models.
ORACLE_RUNTIME=local
CLAUDE_BIN=
# Set to the interactive user's home dir (e.g. C:\Users\YourName) so the claude
# CLI finds its OAuth credentials when the worker runs as LocalSystem. Leave blank
# on VPS / non-Windows or when the service runs as the interactive user directly.
CLAUDE_USERPROFILE=

# All-markets LLM executor: one Opus agent reasons over the FULL raw SportyBet
# allMarkets catalogue (900+ per fixture, no family privileged) and picks the
# single best-edge outcome, validated against real quoted odds; the Opus arbiter
# then audits it. Primary decision path for llmEligible fixtures when true; off →
# family-gated deterministic cascade only. Pair with ORACLE_LOCAL_DECISION=true so
# a capable Claude model (not a free OpenRouter fallback) does the reasoning.
ENABLE_LLM_MARKET_EXECUTOR=true

# Temporary scope pivot: goals/BTTS markets only (Goals O/U, Asian 2 Goals, Team
# Total, BTTS). AH/DNB/Double-Chance/Win-Either-Half/First-Half are skipped
# entirely in scanMarkets() — not computed, not just hidden from output. Goal is
# to prove prediction accuracy in goal markets before re-expanding scope to the
# other markets. Set to false to restore full all-markets analysis.
ORACLE_GOALS_ONLY_MODE=true

# ── goals-market-analysis-prompt-v3 ──────────────────────────────────────────
# Deterministic goals-batch pipeline (packages/engine/src/goalsV3,
# packages/runtime/src/goalsV3): eligibility -> weighted completeness gate ->
# multiplicative-Poisson lambdas -> match-shape correction -> §4 edge gate,
# with LLM usage cut to ONE slate-level arbiter call. false = legacy funnel
# (mechanical pre-filter -> Sonnet screen -> full ensemble + per-fixture
# arbiter), byte-identical to pre-v3 behaviour.
ORACLE_GOALS_V3=false
GOALS_V3_COMPLETENESS_MIN=70       # §0.3 weighted score floor (0-100); mandatory-only = exactly 70
GOALS_V3_HEIGHTENED_MIN=85         # §1.2 floor for youth/women/friendly/cup-final fixtures
GOALS_V3_EDGE_CAP=0.12             # §4.4 implausible-edge cap — raw edge above this is discarded, never bet
GOALS_V3_NOISE_GATE=0.02           # §4.3 noise gate — |raw edge| at/below this is discarded
GOALS_V3_XG_BLEND=true             # §3.1 optional 50/50 xG blend into the multiplicative lambda
GOALS_ARBITER_TIMEOUT_MS=120000    # slate-arbiter callClaudeCode timeout
GOALS_V3_ENABLE_BTTS=false         # BTTS priced but excluded from slips pending booking-label verification
# Extends the v3 cap + noise gate (NOT the penalty table — those inputs are
# goals-sidecar-specific) to goals-family markets (Goals O/U, Team Total,
# BTTS) in the MAIN all-markets batch's scanMarkets admission. Independent of
# ORACLE_GOALS_V3 — the goals-only batch always runs these gates; this flag
# extends the same protection to the shared daily pipeline. Non-goals
# families are untouched either way.
ORACLE_V3_MAIN_GATES=false

# Audit P0-2: use lake-computed league goal baselines (goals/game per league)
# instead of the static V3_LEAGUE_BASELINES table for the v3 λ core. Default off
# ⇒ static table only (byte-identical to prior behavior). Before flipping on,
# run `python tools/compute_league_baselines.py --report` to (a) regenerate
# .tmp/oracle-store/league_baselines.json and (b) SEE the per-league diff vs the
# static table — this is a live pricing change (a stale hardcoded L is replaced
# by a fresh recency-weighted figure). Fails open to the static table if the
# JSON is missing/unusable. The worker's startup config line reports how many
# baselines loaded.
ORACLE_V3_LAKE_BASELINES=off

# Full-audit P3: use per-league HFA multipliers fitted from the same results
# lake (m = sqrt(home gpg / away gpg), clamped [1.0, 1.30]) instead of the single
# global ORACLE_V3_HFA (1.10) for the all-markets λ core. Default off ⇒ global
# HFA everywhere. Reads hfaByName from the same league_baselines.json the tool
# above writes, so run `python tools/compute_league_baselines.py --report` first
# (its output now shows the fitted per-league hfa=… column). Falls back to the
# global v3Hfa for any league absent from the map. Only affects the all-markets
# pipeline (the goals-only path passes no HFA — a separate pre-existing gap).
ORACLE_V3_LAKE_HFA=off

# Wave-4-accuracy: market-anchored blend pricing for ALL v3 candidates (not just
# odds ≥ 4.00). On ⇒ every candidate's gate/EV/confidence/ranking/stake is
# evaluated on pBlend = (1−wModel)·q_fair + wModel·P_model with rescaled class
# bars (S≥1.0/M≥1.5/L≥2.0/X≥2.0 blended pts + blend-EV floors); caps + noise
# floor stay on RAW edge so shrinking can never admit a capped pick. This is the
# fix for fake soft-market edges (e.g. Highest Scoring Half). Off ⇒ byte-identical
# legacy raw-edge gating (rollback lever). Default on per owner decision.
ORACLE_V3_BLEND_PRICING=on

# Wave-4-accuracy: empirical hit-rate blend for totals O/U 1.5/2.5/3.5 (same
# w = 0.3·min(n,5)/5 convention shape.ts uses for BTTS%/CS%). GOALS COUNTER ONLY —
# corners/cards/team-total reuse of the O/U pricer stays model-only. Off ⇒
# model-only totals (prior behavior). Default on per owner decision.
ORACLE_V3_TOTALS_EMPIRICAL=on

# X-carveout (2026-07-11): high-conviction Class X exception to the blend gate.
# Class X exotics (correct_score/exact_goals/ht_ft/combo/specials/exotic) are
# unreachable under ORACLE_V3_BLEND_PRICING by construction (the raw-space -5pt
# exotic penalty can never be out-earned by a blend-space edge). This flag is the
# repo's ONLY deliberate gate relaxation: shadow ⇒ tag would-pass X candidates
# (assessment xCarveout: "shadow_pass") for ledger evidence, picks unchanged;
# on ⇒ admit qualifying X candidates at confidence "medium". Qualifying still
# requires EVERY other X bar at full strength (odds<=15, blendEV>=12%, EV floor,
# raw caps/noise) PLUS confirmed real xG AND completeness >= 0.8 AND the penalty
# rescaled into blend units (x1/3) still clearing the 0.02 edge floor. Default
# off. Flip to shadow first; promote on ledger evidence only.
ORACLE_V3_X_CARVEOUT=off

# Patterns-engine Wave 1: pattern/trend-detection gate. shadow (default) computes
# and logs pattern signals without gating picks; on makes them gating (later
# wave); off disables entirely.
ORACLE_V3_PATTERNS=shadow

# ── Tuning ────────────────────────────────────────────────────────────────────
BANKROLL=1000
BATCH_CONCURRENCY=3          # 3 = safe for 8 GB local machine; use 8 on Railway/cloud
MAX_FIXTURES_PER_RUN=50    # pre-analysis cap — SportyBet-today gated, best-N by composite score
WEB_ODDS_MIN_CONSENSUS=3
WEB_ODDS_VARIANCE_THRESHOLD=0.025
PORT=8787                  # web UI port; binds 0.0.0.0 by default for cloud deployment —
                            # set HOST=127.0.0.1 for local-only (see apps/web/src/server.ts)

# ── Push notifications (@oracle/notify — all optional) ───────────────────────
TELEGRAM_BOT_TOKEN=        # with TELEGRAM_CHAT_ID → Telegram push + punt bot
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=
MAIL_API_KEY=              # Resend-style HTTP mail API
MAIL_FROM=
MAIL_TO=
# MAIL_ENDPOINT=https://api.resend.com/emails
OPENCLAW_GATEWAY_URL=      # e.g. http://127.0.0.1:18789
OPENCLAW_TOKEN=
# OPENCLAW_AGENT_ID=main

# ── Apify reliability fallback (OPTIONAL — leave UNSET to stay dormant) ───────
# DORMANT by default: with APIFY_TOKEN unset there is zero cost and zero behaviour
# change. gismo (Sportradar direct HTTP) remains the PRIMARY stats source — Apify
# is pay-per-event, 1-3s polling-scrape, has no xG, and only fills H2H/standings
# when gismo returns null. Never set this expecting a speed gain; it's reliability
# insurance only. APIFY_MAX_CALLS caps per-run spend even when the token is set.
APIFY_TOKEN=
APIFY_MAX_CALLS=20
